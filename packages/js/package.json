{
  "name": "@softlaunch/js",
  "version": "0.1.0-beta.0",
  "description": "Softlaunch feature flag SDK for JavaScript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayoung19/softlaunch.git",
    "directory": "packages/sdk-js"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@instantdb/core": "0.22.158",
    "@softlaunch/core": "workspace:*"
  },
  "devDependencies": {
    "@workspace/typescript-config": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "5.9.3"
  }
}
