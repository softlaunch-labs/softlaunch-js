{
  "name": "@softlaunch/core",
  "version": "0.1.0",
  "description": "Softlaunch feature flag evaluation engine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayoung19/softlaunch.git",
    "directory": "packages/sdk-core"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "@workspace/typescript-config": "workspace:*",
    "tsup": "^8.4.0",
    "typescript": "5.9.3",
    "vitest": "^3.1.1"
  }
}
